# =============================================================================
# Vercel Environment Variables
# Copy these keys into Vercel Project Settings -> Environment Variables.
# Do not commit real secrets.
# =============================================================================

# --- Runtime -----------------------------------------------------------------
AUTH_COOKIE_SECURE=true
# Use managed Postgres for durable auth on serverless deployments.
AUTH_DATABASE_URL=
AUTH_DATABASE_SSL=true
# Fallback only for local/single-instance runtime. Not durable across cold starts.
# AUTH_DATA_DIR=/tmp/anotherme-auth
# Optional stable admin login.
AUTH_ADMIN_EMAIL=
AUTH_ADMIN_PASSWORD=
AUTH_ADMIN_DISPLAY_NAME=管理员
AUTH_SECRET=

# --- LLM Providers -----------------------------------------------------------
# Configure at least one provider and set DEFAULT_MODEL accordingly.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODELS=

ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
ANTHROPIC_MODELS=

GOOGLE_API_KEY=
GOOGLE_BASE_URL=
GOOGLE_MODELS=

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=
DEEPSEEK_MODELS=

QWEN_API_KEY=
QWEN_BASE_URL=
QWEN_MODELS=

DEFAULT_MODEL=openai:gpt-4o-mini

# --- AnotherMe2 Gateway on Alibaba Cloud -------------------------------------
# Use HTTPS/WSS domains that point to your Alibaba Cloud gateway.
ANOTHERME2_GATEWAY_BASE_URL=https://api.example.com
ANOTHERME2_GATEWAY_WS_BASE_URL=wss://api.example.com
ANOTHERME2_GATEWAY_TOKEN=

# Required when video generation should be submitted to the Alibaba Cloud gateway.
NEXT_PUBLIC_VIDEO_GENERATION_MODE=gateway-job

# --- Optional Media Providers ------------------------------------------------
TTS_OPENAI_API_KEY=
TTS_OPENAI_BASE_URL=

IMAGE_QWEN_IMAGE_API_KEY=
IMAGE_QWEN_IMAGE_BASE_URL=

VIDEO_SEEDANCE_API_KEY=
VIDEO_SEEDANCE_BASE_URL=

TAVILY_API_KEY=

# --- Security ----------------------------------------------------------------
# Keep disabled on public Vercel deployments.
ALLOW_LOCAL_NETWORKS=false
